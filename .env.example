# Secrets accept a <NAME>_FILE variant that is read from a mounted file and
# takes precedence over <NAME>. A configured but unreadable or empty file is a
# startup error rather than a fallback.

APP_ENV=

DISCORD_TOKEN=
DISCORD_TOKEN_FILE=

GOOGLE_API_KEY=
GOOGLE_API_KEY_FILE=
AI_BASE_PROMPT=

SCAM_DETECT_URL=http://ocr-scam-detect:8000
SCAM_DETECT_TOKEN=
SCAM_DETECT_TOKEN_FILE=
SCAM_DETECT_QUEUE_CAPACITY=128
SCAM_DETECT_WORKERS=2
SCAM_DETECT_MAX_IMAGES_PER_MESSAGE=3
SCAM_DETECT_MAX_UPLOAD_MB=10
SCAM_DETECT_DOWNLOAD_TIMEOUT_SECS=10
SCAM_DETECT_SCAN_TIMEOUT_SECS=30
SCAM_DETECT_JOB_TTL_SECS=120

REDIS_URL=redis://redis:6379

MONGO_URI=mongodb://mongo:27017
MONGO_USERNAME=homestead
MONGO_PASSWORD=secret
MONGO_PASSWORD_FILE=
MONGO_AUTH_SOURCE=admin
MONGO_DATABASE=local
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_SSL=false
MONGO_TLS_CA_FILE=
MONGO_TLS_CERT_KEY_FILE=
MONGO_TLS_INSECURE=
